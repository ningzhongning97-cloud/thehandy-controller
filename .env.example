# The Handy Controller Configuration
# Copy this file to .env and fill in your values

# Kimi API Key (https://platform.moonshot.cn)
KIMI_API_KEY=your_kimi_api_key_here

# API Configuration
# Get your Connection Key from https://www.handyfeeling.com
HANDY_CONNECTION_KEY=your_connection_key_here
HANDY_API_URL=https://www.handyfeeling.com/api/v1

# Request Configuration
HANDY_REQUEST_TIMEOUT=10
HANDY_MAX_RETRIES=3

# Device Configuration (optional)
HANDY_DEVICE_ID=

# Logging Configuration
HANDY_LOG_LEVEL=INFO
HANDY_LOG_FILE=thehandy.log
